# Public application settings
NEXT_PUBLIC_APP_URL=https://toko-online-general-purpose.vercel.app/
NEXT_PUBLIC_APP_NAME=NusaMart

# Supabase (use the publishable key for new projects; anon is a legacy fallback)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Midtrans (used in the checkout phase)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_NOTIFICATION_URL=

# Store defaults
NEXT_PUBLIC_DEFAULT_WHATSAPP_NUMBER=
LOG_LEVEL=info
ORDER_NUMBER_PREFIX=ORD
LOW_STOCK_THRESHOLD=5
