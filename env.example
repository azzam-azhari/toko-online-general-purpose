# Required by every build/server environment
NEXT_PUBLIC_APP_URL=https://toko-online-general-purpose.vercel.app/
NEXT_PUBLIC_APP_NAME=NusaMart

# Required Supabase API/auth/database configuration.
# Use the publishable key for new hosted projects; anon is a legacy/local fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret. Never expose this value through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Optional/deferred external checkout integration; the current storefront does not call Midtrans.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_NOTIFICATION_URL=

# Optional storefront and operational defaults
NEXT_PUBLIC_DEFAULT_WHATSAPP_NUMBER=
LOG_LEVEL=info
ORDER_NUMBER_PREFIX=ORD
LOW_STOCK_THRESHOLD=5
